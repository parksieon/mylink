// Firestore Rules — Firebase 콘솔 → Firestore → Rules 탭에 붙여넣고 Publish 하세요.
// 이 파일은 참고용이며 자동 배포되지 않습니다.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // 외부 링크 url 화이트리스트 — http(s) 만, javascript:·data: 등 차단
    function isSafeHttpUrl(v) {
      return v is string && v.matches('^https?://.+');
    }

    // 업로드 파일 URL 화이트리스트 — Firebase Storage 호스트만
    function isFirebaseStorageUrl(v) {
      return v is string && v.matches('^https://firebasestorage[.]googleapis[.]com/.+');
    }

    // BGM URL 화이트리스트 — YouTube 도메인만 (또는 빈 문자열로 BGM 해제)
    function isYoutubeOrEmpty(v) {
      return v is string && (v == '' ||
        v.matches('^https?://(www[.]|m[.]|music[.])?youtube[.]com/.+') ||
        v.matches('^https?://youtu[.]be/.+'));
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // url·fileURL·bgImageURL 변경 시 형식 강제
    function nodeUrlFieldsOk() {
      return (!affectedKeys().hasAny(['url']) || isSafeHttpUrl(request.resource.data.url))
        && (!affectedKeys().hasAny(['fileURL']) ||
            request.resource.data.fileURL == null ||
            isFirebaseStorageUrl(request.resource.data.fileURL))
        && (!affectedKeys().hasAny(['bgImageURL']) ||
            request.resource.data.bgImageURL == null ||
            isFirebaseStorageUrl(request.resource.data.bgImageURL));
    }

    function createNodeUrlFieldsOk() {
      return (!('url' in request.resource.data) || isSafeHttpUrl(request.resource.data.url))
        && (!('fileURL' in request.resource.data) ||
            request.resource.data.fileURL == null ||
            isFirebaseStorageUrl(request.resource.data.fileURL))
        && (!('bgImageURL' in request.resource.data) ||
            request.resource.data.bgImageURL == null ||
            isFirebaseStorageUrl(request.resource.data.bgImageURL));
    }

    // username 형식 + 예약어 차단 (룰 단에서도 검증, 클라 정규식과 동일)
    function isValidUsername(u) {
      return u is string
        && u.matches('^[a-z0-9][a-z0-9_-]{2,19}$')
        && !(u in [
          'admin', 'administrator', 'root', 'support', 'help',
          'api', 'www', 'mail', 'about', 'home',
          'signin', 'signup', 'login', 'logout', 'signout',
          'settings', 'profile', 'mypage',
          'user', 'users', 'me', 'system',
          'timefilm', 'mylink'
        ]);
    }

    // usernames — 본인 uid 매칭된 문서만 생성/삭제, 수정 불가 (스쿼팅 방지)
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && isValidUsername(username)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // 글로벌 venue 캐시 (Interpark 공연장 layout) — Admin SDK만 write
    match /venues/{placeCode} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 공연(취소표 모니터) — 전역 공유. Admin SDK만 write
    match /concerts/{cid} {
      allow read: if request.auth != null;
      allow write: if false;

      // 구독자 — 본인 uid 매칭된 문서만 self-write
      match /subscribers/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // 알림 이력 — read-only (Admin SDK가 write)
      match /alerts/{aid} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // /tickets 대시보드가 collectionGroup('subscribers') + where('uid' == 본인) 쿼리로
    // 본인이 구독한 모든 공연을 가져오는 경로. 위의 nested rule 만으론 collection group
    // 쿼리가 차단되므로 path wildcard 매처를 명시.
    // doc id 가 본인 uid 인 경우만 read — 다른 사용자의 구독 정보 enumerate 차단.
    match /{path=**}/subscribers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if true;

      // 프로필 본문 — 본인만. quotaBytes는 콘솔에서만 수정 가능.
      // 알려진 한계: 본인이 usedBytes를 임의로 0으로 리셋해서 quota 우회 가능 (학기 프로젝트 용인).
      allow create: if isOwner(uid)
        && (!('bgmYoutubeUrl' in request.resource.data) || isYoutubeOrEmpty(request.resource.data.bgmYoutubeUrl));
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['quotaBytes'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['bgmYoutubeUrl'])
            || isYoutubeOrEmpty(request.resource.data.bgmYoutubeUrl));

      // FCM 디바이스 토큰 — 본인만 read/write. 공개 read 인 users/{uid} 문서에
      // fcmTokens 배열을 보관하면 누구나 토큰을 enumerate 할 수 있어 서브컬렉션으로 분리.
      match /devices/{tid} {
        allow read, write: if isOwner(uid);
      }

      // 통합 노드 컬렉션 (folder | article | link | html | 3d | pdf)
      match /nodes/{nodeId} {
        allow read: if isOwner(uid)
          || resource.data.effectiveVisibility == "public";

        allow create: if isOwner(uid)
          && request.resource.data.depth >= 0
          && request.resource.data.depth <= 3
          && createNodeUrlFieldsOk();

        allow delete: if isOwner(uid);

        // 본인 자유 수정 (단 url·fileURL·bgImageURL 형식 강제)
        // OR 익명/비로그인이 link의 clickCount만 +1
        allow update: if (isOwner(uid) && nodeUrlFieldsOk())
          || (
            resource.data.kind == "link"
            && resource.data.effectiveVisibility == "public"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount'])
            && request.resource.data.clickCount == resource.data.clickCount + 1
          );
      }
    }
  }
}
