// Storage Rules — Firebase 콘솔 → Storage → Rules 탭에 붙여넣고 Publish 하세요.
// 이 파일은 참고용이며 자동 배포되지 않습니다.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 사용자별 파일 (leaf asset + 폴더 배경) — 본인만 100MB 이하 업로드
    match /users/{uid}/files/{nodeId}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 100 * 1024 * 1024;
    }
  }
}
